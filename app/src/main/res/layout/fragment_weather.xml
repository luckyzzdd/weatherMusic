<!-- 外层根布局不变，新增容器包裹目标控件 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_light">

    <!-- 核心：新增容器（CardView，灰色背景+圆角） -->
    <androidx.cardview.widget.CardView
        android:id="@+id/weather_card"
        android:layout_width="320dp"
        android:layout_height="280dp"
        android:layout_marginTop="50dp"
        android:padding="16dp"
        app:cardBackgroundColor="@color/pink_soft"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 容器内部用ConstraintLayout排版原有控件 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <!-- 以下是你要包裹的所有控件，布局关系不变 -->
            <TextView
                android:id="@+id/wenDu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="16"
                android:textColor="@color/white"
                android:textSize="100sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/wenDu_circle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/wendu"
                app:layout_constraintStart_toEndOf="@+id/wenDu"
                app:layout_constraintTop_toTopOf="@+id/wenDu"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_city"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="city"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/wenDu" />

            <TextView
                android:id="@+id/tv_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="weather"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_city" />

            <ImageView
                android:id="@+id/iv_weather"
                android:layout_width="20dp"
                android:layout_height="26dp"
                android:layout_marginStart="3dp"
                android:textColor="@color/white"
                app:layout_constraintStart_toEndOf="@+id/tv_weather"
                app:layout_constraintTop_toBottomOf="@+id/tv_city" />

            <TextView
                android:id="@+id/tv_humidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="湿度"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="@id/tv_weather"
                app:layout_constraintTop_toBottomOf="@+id/tv_weather" />

            <TextView
                android:id="@+id/tv_reporttime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="更新时间"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_humidity" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <ProgressBar
        android:id="@+id/isLoading"
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintTop_toBottomOf="@id/weather_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        />
    <!-- 新增：滑动的图标（核心） -->
    <ImageView
        android:id="@+id/iv_slide_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/weather"
        android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@id/weather_card"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="10dp"/>

    <!-- 新增：4天预报水平布局容器 -->
    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/weather_card"
        android:layout_marginTop="70dp"
        >

        <!-- 预报项 1 -->
        <include
            android:id="@+id/forecast_item_1"
            layout="@layout/item_forecast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginBottom="20dp"
         />

        <!-- 预报项 2/3/4 去掉marginTop，用item内部的marginVertical控制间距 -->
        <include
            android:id="@+id/forecast_item_2"
            layout="@layout/item_forecast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <include
            android:id="@+id/forecast_item_3"
            layout="@layout/item_forecast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <include
            android:id="@+id/forecast_item_4"
            layout="@layout/item_forecast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>